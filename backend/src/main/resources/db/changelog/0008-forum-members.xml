<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="0012" author="rideout">
        <comment>Create forum_members join table for user-forum membership</comment>

        <createTable tableName="forum_members">
            <column name="user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="forum_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="joined_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
                tableName="forum_members"
                columnNames="user_id, forum_id"
                constraintName="pk_forum_members"/>

        <addForeignKeyConstraint
                baseTableName="forum_members"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_forum_members_user"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="forum_members"
                baseColumnNames="forum_id"
                referencedTableName="forums"
                referencedColumnNames="id"
                constraintName="fk_forum_members_forum"
                onDelete="CASCADE"/>

        <createIndex tableName="forum_members" indexName="idx_forum_members_forum_id">
            <column name="forum_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
