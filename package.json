{
  "name": "forums",
  "version": "1.0.0",
  "private": true,
  "description": "Forums application monorepo with TypeScript frontend and Java backend",
  "scripts": {
    "prepare": "husky",
    "frontend": "cd frontend && npm run dev",
    "test:frontend": "cd frontend && npm test",
    "e2e": "cd e2e && npm test",
    "e2e:report": "cd e2e && npm run report",
    "generate:api": "bash ./generate-api.sh"
  },
  "workspaces": [
    "frontend",
    "e2e"
  ],
  "devDependencies": {
    "@commitlint/cli": "^19.7.0",
    "@commitlint/config-conventional": "^19.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
